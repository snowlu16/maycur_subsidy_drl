        // 获取行程中的时间是否有半天或重叠
        int state = isDayHalveOrOverlap(
            $dateMap, 
            $reimEmployee.getUserCode()+2, 
            $dateTime, 
            $startDate, 
            $endDate
        );

        logger.info("补贴测试行程日期为" + $dateTime +",补贴测试报销人编号为" + $reimEmployee.getUserCode() + ",补贴测试日期判断状态为" + state);

        if(state == 1) {
