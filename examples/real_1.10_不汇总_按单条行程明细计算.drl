                $dateTime, 
                $secondFeeCode, 
                allowanceAmount,
                $baseCcy, 
                $collectionCcy, 
                $destination
            ));
        } else if (state == 0) {
            insert(new AllowanceResult(
                $dateTime, 
                $secondFeeCode, 
                allowanceAmount.divide(BigDecimal.valueOf(2)),
                $baseCcy, 
                $collectionCcy, 
                $destination
            ));
        }
end

